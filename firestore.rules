rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if a user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Admin: Full access
      allow read, write: if isAdmin();
      
      // Student: Can read/write their own document only
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Teacher: Can read student documents assigned to them
      allow read: if request.auth != null && 
        resource.data.role == 'student' && 
        resource.data.assignedTeacherId == request.auth.uid;
    }

    match /classes/{classId} {
      allow read, write: if isAdmin();
      // Teacher: Can read their own classes
      allow read: if request.auth != null && resource.data.teacherId == request.auth.uid;
      // Student: Can read classes they are in
      allow read: if request.auth != null && request.auth.uid in resource.data.studentIds;
    }

    match /assignments/{assignmentId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null; // Refine based on actual assignment structure
    }

    match /demo_bookings/{bookingId} {
      // Anyone can create a demo booking
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    match /materials/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /user_status_logs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /attendance/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && resource.data.studentId == request.auth.uid;
      // Teachers read/write if they are the teacher assigned
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
  }
}
